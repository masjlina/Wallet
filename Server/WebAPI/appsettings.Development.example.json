{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnStr": "Host=localhost;Port=5432;Username=your_db_user;Password=your_db_password;Database=Wallet;Include Error Detail=true",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5500"
    ]
  },
  "Authentication": {
    "Schemes": {
      "Bearer": {
        "ValidAudiences": [
          "http://localhost:9273",
          "https://localhost:44330",
          "http://localhost:5231",
          "https://localhost:7072"
        ],
        "ValidIssuer": "wallet-api",
        "SigningKeys": [
          {
            "Issuer": "wallet-api",
            "Value": "replace-with-base64-signing-key"
          }
        ]
      }
    }
  }
}
